<?xml version="1.0" encoding="utf-8"?>
<AutoVisualizer xmlns="http://schemas.microsoft.com/vstudio/debugger/natvis/2010">
  <!-- Sora value-type visualizers. Keep STL layout fallbacks in libcxx.natvis. -->

  <Type Name="Sora::EnumSet&lt;*&gt;">
    <DisplayString>{{ capacity={kSize}, bits={bits_} }}</DisplayString>
    <Expand>
      <Item Name="[capacity]">kSize</Item>
      <Item Name="[bits]">bits_</Item>
    </Expand>
  </Type>
</AutoVisualizer>
