{
  // ─── Terminal: default to PowerShell with coca-toolchain-p2996 env ───
  "terminal.integrated.defaultProfile.windows": "coca-p2996",
  "terminal.integrated.profiles.windows": {
    "coca-p2996": {
      "source": "PowerShell",
      "args": ["-NoExit", "-File", "${workspaceFolder}/scripts/coca-env.ps1"],
      "icon": "terminal-powershell",
      "overrideName": true
    }
  },

  // ─── CMake ───
  "cmake.generator": "Ninja",
  "cmake.cmakePath": "T:/toolchains/coca-toolchain-p2996/tools/cmake/bin/cmake.exe",
  "cmake.buildDirectory": "${workspaceFolder}/build/${buildKit}",

  // ─── IntelliSense (clangd) ───
  "clangd.path": "T:\\toolchains\\coca-toolchain-p2996\\bin\\clangd.exe",
  "clangd.arguments": [
    "--compile-commands-dir=${workspaceFolder}/build/x64-asan",
    "--background-index",
    "--clang-tidy"
  ],

  // ─── TestMate C++: test discovery + coverage ───
  // Use x64-coverage (no sanitizers) for stable coverage collection.
  // ASan+coverage combo is unstable on Windows debug CRT; use x64-asan separately.
  "testMate.cpp.test.executables": "${workspaceFolder}/build/x64-coverage/bin/Test.*.exe",
  "testMate.cpp.experimental.llvm-cov": {
    "enabled": true,
    "logpanel": true
  }
}
